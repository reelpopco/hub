{
  "manifest_version": 3,
  "name": "릴팝 Flow 자동화",
  "version": "1.0",
  "description": "든든백세·은혜여사·조선의여인들 이미지 프롬프트를 Google Flow에 자동 입력",
  "permissions": ["storage", "activeTab", "scripting", "downloads"],
  "host_permissions": [
    "https://labs.google/*",
    "https://reelpopco.github.io/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://labs.google/fx/ko/tools/flow*"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
